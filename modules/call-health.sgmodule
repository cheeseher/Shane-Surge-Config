#!name=Telegram 与 Zoom 通话健康
#!desc=读取 Surge 当前及近期真实连接，显示 Telegram、Zoom 的 UDP/TCP 路径、基础连通性与最终节点。Amy AnyTLS 可能显示 TCP 回退，请结合双向语音实测。
#!category=Shane-Surge

[Panel]
通话健康 = title="Telegram / Zoom 通话健康", content="开始通话并保持 10–20 秒\n返回 Surge 后点击刷新", icon=phone.fill, icon-color=#6A9BCC, script-name=Shane 通话健康, update-interval=30

[Script]
Shane 通话健康 = type=generic, script-path=https://raw.githubusercontent.com/cheeseher/Shane-Surge-Config/main/scripts/surge/call-health.js?v=20260724-anytls1, script-update-interval=86400, timeout=20
