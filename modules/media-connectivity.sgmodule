#!name=媒体连通性监测
#!desc=检测 Netflix、YouTube、Disney+、Prime Video、Max 与 TikTok 的基础网络连通性。检测不等于片库、会员或版权地区解锁保证。
#!category=Shane-Surge

[Panel]
媒体连通性 = title="媒体连通性", content="N  Netflix       \t      --  ⚪️\n▶  YouTube       \t      --  ⚪️\n◠  Disney+       \t      --  ⚪️\n▷  Prime Video   \t      --  ⚪️\nM  Max           \t      --  ⚪️\n♪  TikTok        \t      --  ⚪️\n\n点击刷新开始检测", icon=play.tv.fill, icon-color=#6A9BCC, script-name=Shane 媒体连通性, update-interval=900

[Script]
Shane 媒体连通性 = type=generic, script-path=https://raw.githubusercontent.com/cheeseher/Shane-Surge-Config/main/scripts/surge/media-connectivity.js, script-update-interval=86400, timeout=35
